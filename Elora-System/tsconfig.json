{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": false,
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2019",
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src"
  ]
}
