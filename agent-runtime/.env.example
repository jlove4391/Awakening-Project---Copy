# Agent runtime local development
AGENT_RUNTIME_PORT=4317
AGENT_RUNTIME_CORS_ORIGIN=http://localhost:3000
AGENT_RUNTIME_DATA_DIR=./.runtime-data

# Google OAuth local verification
GOOGLE_CLIENT_ID=replace-with-your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4317/api/auth/google/callback
GOOGLE_TOKEN_STORE_KEY=replace-with-at-least-32-random-characters
# MASTER_KEY can be used instead of GOOGLE_TOKEN_STORE_KEY.
# MASTER_KEY=replace-with-at-least-32-random-characters

# Optional smoke-test settings
GOOGLE_CALENDAR_ID=primary
SMOKE_SESSION_ID=local-google-calendar-smoke
SMOKE_MAX_RESULTS=10
# SMOKE_TIME_MIN=2026-06-11T00:00:00.000Z
# SMOKE_TIME_MAX=2026-06-18T00:00:00.000Z
