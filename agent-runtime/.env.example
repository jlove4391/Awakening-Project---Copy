# Agent runtime
AGENT_RUNTIME_PORT=4317
AGENT_RUNTIME_CORS_ORIGIN=http://localhost:3000
AGENT_RUNTIME_PUBLIC_BASE_URL=http://localhost:4317
AGENT_RUNTIME_DATA_DIR=.runtime-data
AGENT_RUNTIME_SESSION_BACKEND=auto

# OpenAI / SDK
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
ELORA_MODEL=gpt-5.4

# Google OAuth / Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4317/api/auth/google/callback
GOOGLE_TOKEN_STORE_KEY=
MASTER_KEY=
GOOGLE_TOKEN_STORE_PATH=

# Nexora code workspace
NEXORA_WORKSPACE_ROOT=
CODE_WORKSPACE_ROOT=
NEXORA_CODE_COMMAND_TIMEOUT_MS=120000
CODE_COMMAND_TIMEOUT_MS=120000

# Voice
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
VOICE_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_SPEECH_MODEL=gpt-4o-mini-tts
VOICE_SPEECH_MODEL=gpt-4o-mini-tts
OPENAI_SPEECH_VOICE=marin
VOICE_SPEECH_VOICE=marin
OPENAI_SPEECH_FORMAT=mp3
VOICE_SPEECH_FORMAT=mp3
OPENAI_SPEECH_INSTRUCTIONS=Speak as Elora: composed, clear, concise, and operationally transparent.
VOICE_SPEECH_INSTRUCTIONS=Speak as Elora: composed, clear, concise, and operationally transparent.

# Telephony / voice calling
AGENT_RUNTIME_TELEPHONY_STREAM_PATH=/api/voice/telephony/stream
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MISSED_CALL_SESSION_ID=missed-calls

# Meeting adapters
ZOOM_MEETING_ADAPTER_URL=
TEAMS_MEETING_ADAPTER_URL=
GOOGLE_MEET_ADAPTER_URL=

# Future CRM / enrichment providers
CRM_PROVIDER=
CRM_API_KEY=
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REFRESH_TOKEN=
CLAY_API_KEY=
